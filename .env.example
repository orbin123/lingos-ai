# ========================================
# Application
# ========================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# ========================================
# Database (PostgreSQL)
# ========================================
POSTGRES_USER=coach
POSTGRES_PASSWORD=change_me
POSTGRES_DB=coach_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://coach:change_me@localhost:5432/coach_db

# ========================================
# Redis
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ========================================
# Authentication
# ========================================
JWT_SECRET=generate_a_long_random_string_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================
# AI Services
# ========================================
OPENAI_API_KEY=sk-replace-me
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_replace-me
LANGCHAIN_PROJECT=ai-english-coach
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ========================================
# Text-to-Speech (OpenAI)
# ========================================
# Model + default voice for TTS. The voice can be overridden per-call.
# Voices for gpt-4o-mini-tts: alloy, ash, ballad, coral, echo, fable,
# onyx, nova, sage, shimmer, verse.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# Where synthesized audio is cached on disk + which URL prefix it's
# served under by FastAPI's StaticFiles mount.
TTS_CACHE_DIR=app/ai/tts/_cache
TTS_PUBLIC_URL_PREFIX=/audio

# ========================================
# Speech-to-Text (OpenAI)
# ========================================
# whisper-1 is the only OpenAI STT model that supports word-level
# timestamps (needed for fluency analysis on speak_* tasks).
OPENAI_STT_MODEL=whisper-1
# Where transcript JSON sidecar files are cached on disk.
STT_CACHE_DIR=app/ai/stt/_cache

# ========================================
# Pronunciation Scoring (Azure Speech)
# ========================================
# Azure Speech resource used for pronunciation assessment.
AZURE_SPEECH_KEY=replace-me
AZURE_SPEECH_REGION=eastus
# Where pronunciation-score JSON sidecar files are cached on disk.
PRONUNCIATION_CACHE_DIR=app/ai/pronunciation/_cache

# ========================================
# Image Generation (OpenAI)
# ========================================
# `gpt-image-2` is OpenAI's current flagship image-generation model.
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=png
# Where generated images are cached on disk + which URL prefix they're
# served under by FastAPI's StaticFiles mount.
IMAGEGEN_CACHE_DIR=app/ai/imagegen/_cache
IMAGEGEN_PUBLIC_URL_PREFIX=/images

# ========================================
# Vector DB (Pinecone)
# ========================================
# IMPORTANT: the app does NOT create the index — you must create it manually
# in the Pinecone console BEFORE feedback-memory data can appear:
#   • Name      = PINECONE_INDEX_NAME below
#   • Dimension = OPENAI_EMBEDDING_DIMENSIONS below (1024) — a mismatch makes
#                 every upsert fail silently
#   • Metric    = cosine
#   • Cloud/region = match PINECONE_CLOUD / PINECONE_REGION
# Verify with:  cd backend && uv run python scripts/check_pinecone.py
PINECONE_API_KEY=replace-me
PINECONE_INDEX_NAME=lingosai-responses
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Namespace for feedback memory vectors (keeps them isolated from
# other vectors in the same index). Auto-created on first upsert.
PINECONE_FEEDBACK_NAMESPACE=feedback_memory

# ========================================
# RAG / Embeddings
# ========================================
# text-embedding-3-small is the cheapest OpenAI embedding model ($0.02/1M tokens).
# Dimensions reduced from 1536 to 1024 for cost efficiency. Must match the
# Pinecone index dimension above.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1024
# A normalized mistake must recur in at least this many past activities to be
# called out as a "recurring pattern" in the Coach's Note.
RAG_RECURRENCE_MIN_COUNT=2
# Make per-activity feedback memory-aware (advisory only; never changes score).
# Off by default.
RAG_PER_ACTIVITY_FEEDBACK=false
# RAG is best-effort and never blocks the chat flow. These bound how long the
# request path will wait on it before falling back:
#   - per-OpenAI-embedding call / per-Pinecone op
OPENAI_EMBEDDING_TIMEOUT_S=30
PINECONE_OPERATION_TIMEOUT_S=30
#   - inline Coach's Note wait at session completion (note still finishes in the
#     background if it exceeds this)
RAG_MENTOR_NOTE_TIMEOUT_S=8
#   - per-activity memory retrieval (only used when RAG_PER_ACTIVITY_FEEDBACK=true)
RAG_PER_ACTIVITY_TIMEOUT_S=5
