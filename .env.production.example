# =============================================================================
# LingosAI — PRODUCTION env template
# =============================================================================
# Copy to your server's .env and fill every <placeholder>. The backend enforces
# a fail-fast guard (app/core/config.py::_guard_production): with
# ENVIRONMENT=production it REFUSES TO BOOT if any of these are unsafe —
#   DEBUG, SQL_ECHO, DEV_OTP_BYPASS must be false
#   OTP_HASHING_SECRET must be set (no jwt_secret fallback in prod)
#   AUTH_COOKIE_SECURE must be true
#   CORS_ORIGINS must be set and contain NO localhost / 127.0.0.1 origin
# So a forgotten override surfaces at startup, not as a silent security hole.
# =============================================================================

# ========================================
# Application
# ========================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
# Never echo SQL in prod — it floods logs and can leak schema/PII.
SQL_ECHO=false
# The deployed frontend origin(s), comma-separated. NO localhost.
CORS_ORIGINS=https://app.yourdomain.com

# ========================================
# Database (PostgreSQL) — managed instance, not the dev compose Postgres
# ========================================
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>

# ========================================
# Redis — used for AI rate-limit buckets (multi-worker safe) + locks
# ========================================
REDIS_URL=redis://<host>:6379/0

# ========================================
# Authentication
# ========================================
# Generate: openssl rand -hex 32
JWT_SECRET=<long-random-string>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh-cookie sessions. MUST be secure behind https. Frontend + backend must
# share a registrable domain (app.example.com / api.example.com) — SameSite=Lax.
ACCESS_TOKEN_TTL_MINUTES=20
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_REMEMBER_DAYS=90
AUTH_COOKIE_SECURE=true

# ========================================
# Email delivery + OTP verification
# ========================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM="LingosAI <noreply@yourdomain.com>"
CONTACT_RECIPIENT_EMAIL=support@yourdomain.com
# REQUIRED in prod — distinct from JWT_SECRET. Generate: openssl rand -hex 32
OTP_HASHING_SECRET=<distinct-long-random-string>
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5
OTP_MAX_VERIFY_ATTEMPTS=5
# MUST be false — true would let anyone verify any account with "123456".
DEV_OTP_BYPASS=false

# ========================================
# Razorpay (Live Mode)
# ========================================
RAZORPAY_KEY_ID=<rzp_live_...>
RAZORPAY_KEY_SECRET=<live-secret>
RAZORPAY_WEBHOOK_SECRET=<webhook-secret>

# ========================================
# Google OAuth
# ========================================
GOOGLE_CLIENT_ID=<client-id>
GOOGLE_CLIENT_SECRET=<client-secret>
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/auth/google/callback

# ========================================
# Sentry
# ========================================
SENTRY_DSN=<sentry-dsn>
SENTRY_TRACES_SAMPLE_RATE=0.1

# ========================================
# Rate limiting (AI endpoints)
# ========================================
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_PER_MINUTE=30
AI_RATE_LIMIT_TRANSCRIBE_PER_MINUTE=20
WS_MESSAGE_RATE_PER_MINUTE=20
WS_A2Z_STREAMS_PER_MINUTE=10

# ========================================
# AI Services
# ========================================
OPENAI_API_KEY=<openai-key>
# DATA RESIDENCY: when true, learner session content/goals/responses are sent to
# api.smith.langchain.com. Defaulted OFF for prod — make a conscious decision and
# document retention before enabling. (See audit A5.)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=<langsmith-key>
LANGCHAIN_PROJECT=ai-english-coach
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ========================================
# Text-to-Speech (OpenAI)
# ========================================
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
TTS_CACHE_DIR=app/ai/tts/_cache
TTS_PUBLIC_URL_PREFIX=/audio

# ========================================
# Speech-to-Text (OpenAI + Deepgram)
# ========================================
OPENAI_STT_MODEL=whisper-1
STT_CACHE_DIR=app/ai/stt/_cache
DEEPGRAM_API_KEY=<deepgram-key>

# ========================================
# Pronunciation Scoring (Azure Speech)
# ========================================
AZURE_SPEECH_KEY=<azure-speech-key>
AZURE_SPEECH_REGION=eastus
PRONUNCIATION_CACHE_DIR=app/ai/pronunciation/_cache

# ========================================
# Image Generation (OpenAI)
# ========================================
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=png
IMAGEGEN_CACHE_DIR=app/ai/imagegen/_cache
IMAGEGEN_PUBLIC_URL_PREFIX=/images

# ========================================
# Vector DB (Pinecone) — create the index manually first (dimension 1024, cosine)
# ========================================
PINECONE_API_KEY=<pinecone-key>
PINECONE_INDEX_NAME=lingosai-responses
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_FEEDBACK_NAMESPACE=feedback_memory

# ========================================
# RAG / Embeddings
# ========================================
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1024
RAG_RECURRENCE_MIN_COUNT=2
RAG_PER_ACTIVITY_FEEDBACK=false
OPENAI_EMBEDDING_TIMEOUT_S=30
PINECONE_OPERATION_TIMEOUT_S=30
RAG_MENTOR_NOTE_TIMEOUT_S=8
RAG_PER_ACTIVITY_TIMEOUT_S=5
