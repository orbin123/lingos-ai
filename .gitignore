# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
# Ignore /docs CONTENTS (not the dir itself) so the negation below can
# re-include one folder — git can't re-include under a fully-excluded parent.
/docs/*
# …but version the post-GPT-5 Final Fixes plan + walkthrough + bug
# screenshots so cloud sessions (which clone the remote) can read them.
!/docs/Final_fixes/

# macOS (IMPORTANT for you)
.DS_Store

# Node (for frontend later)
node_modules/
.next/
dist/

# Logs
*.log

# Database
*.db
*.sqlite3
# Postgres dumps (may contain real user data — never commit)
backup*.sql
*.dump

# Root-level ad-hoc/ops scripts (DR drills, dev shortcut) — kept local, not online.
# Anchored with a leading slash so it does NOT also match backend/scripts/.
/scripts/

# Test Files
backend/scratch
# Ignore scripts/ contents (ad-hoc DB tools), but git must descend into the dir
# so the negations below can re-include the test/CI-contract scripts. Excluding
# the dir itself (`backend/scripts`) would make those negations a no-op.
backend/scripts/*
# …but these are part of the test/CI contract, not ad-hoc tooling:
!backend/scripts/__init__.py
!backend/scripts/export_openapi.py
!backend/scripts/run_evals.py
!backend/scripts/calibrate_judge.py
!backend/scripts/golden_set.json
# Production entrypoint — part of the deploy contract, must be committed:
!backend/scripts/start-prod.sh
# DB seeders run by the deploy pipeline (CD) — must ship in the image, not ad-hoc:
!backend/scripts/seed_curriculum.py
!backend/scripts/seed_ielts_challenge.py
!backend/scripts/seed_a2z_challenge.py

# Local archive of deprecated files (kept locally, not committed)
backend/.archive/

# Coverage (pytest-cov / coverage.py)
.coverage
.coverage.*
htmlcov/
coverage.xml

# TTS audio cache (regenerated on demand from OpenAI)
backend/app/ai/tts/_cache/

# STT transcript cache (regenerated on demand from OpenAI)
backend/app/ai/stt/_cache/

# Learner speaking uploads (local dev only)
backend/app/ai/stt/_learner_audio/

# Pronunciation assessment cache (JSON only, never raw user audio)
backend/app/ai/pronunciation/_cache/

# Image-generation cache (regenerated on demand from OpenAI)
backend/app/ai/imagegen/_cache/