# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
/docs

# macOS (IMPORTANT for you)
.DS_Store

# Node (for frontend later)
node_modules/
.next/
dist/

# Logs
*.log

# Database
*.db
*.sqlite3
# Postgres dumps (may contain real user data — never commit)
backup*.sql
*.dump

# Test Files
backend/scratch
backend/scripts

# Local archive of deprecated files (kept locally, not committed)
backend/.archive/

# TTS audio cache (regenerated on demand from OpenAI)
backend/app/ai/tts/_cache/

# STT transcript cache (regenerated on demand from OpenAI)
backend/app/ai/stt/_cache/

# Learner speaking uploads (local dev only)
backend/app/ai/stt/_learner_audio/

# Pronunciation assessment cache (JSON only, never raw user audio)
backend/app/ai/pronunciation/_cache/

# Image-generation cache (regenerated on demand from OpenAI)
backend/app/ai/imagegen/_cache/

/graphify-out/